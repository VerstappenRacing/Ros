<?xml version="1.0"?>
<robot name="bb8_dynamic">

  <!-- ==================== MATERIALS ==================== -->
  <material name="orange">
    <color rgba="1.0 0.42 0.0 1.0"/>
  </material>
  <material name="white">
    <color rgba="0.95 0.95 0.95 1.0"/>
  </material>
  <material name="silver">
    <color rgba="0.75 0.75 0.78 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.05 0.05 0.05 1.0"/>
  </material>

  <!-- ==================== BASE FRAME ==================== -->
  <link name="base_link"/>

  <!-- 구체 중심 기준점 -->
  <joint name="base_to_center" type="fixed">
    <parent link="base_link"/>
    <child link="body_center"/>
    <origin xyz="0 0 0.4"/>
  </joint>
  <link name="body_center"/>

  <!-- ==================== BODY (구르는 주황색 몸통 + 얇은 밴드) ==================== -->
  <joint name="body_roll_joint" type="continuous">
    <parent link="body_center"/>
    <child link="body_link"/>
    <origin xyz="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="body_link">
    <!-- 주황색 구형 몸통 -->
    <visual>
      <geometry>
        <sphere radius="0.4"/>
      </geometry>
      <material name="orange"/>
    </visual>

    <!-- 얇은 흰색 무늬 밴드 1 -->
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.402" length="0.02"/>
      </geometry>
      <material name="white"/>
    </visual>

    <!-- 얇은 흰색 무늬 밴드 2 -->
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.402" length="0.02"/>
      </geometry>
      <material name="white"/>
    </visual>

    <!-- 얇은 흰색 무늬 밴드 3 -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.402" length="0.02"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <!-- ==================== HEAD (조향/회전하는 머리 + 대형 검은 눈) ==================== -->
  <joint name="head_yaw_joint" type="continuous">
    <parent link="body_center"/>
    <child link="head_link"/>
    <origin xyz="0 0 0.38" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="head_link">
    <!-- 흰색 머리 돔 -->
    <visual>
      <origin xyz="0 0 0.1"/>
      <geometry>
        <sphere radius="0.27"/>
      </geometry>
      <material name="white"/>
    </visual>

    <!-- 머리 하단 실버 링 -->
    <visual>
      <origin xyz="0 0 0.02"/>
      <geometry>
        <cylinder radius="0.268" length="0.02"/>
      </geometry>
      <material name="silver"/>
    </visual>

    <!-- 대형 검은색 메인 눈 -->
    <visual>
      <origin xyz="0.22 0 0.18" rpy="0 1.25 0"/>
      <geometry>
        <sphere radius="0.085"/>
      </geometry>
      <material name="black"/>
    </visual>

    <!-- 보조 검은색 눈 -->
    <visual>
      <origin xyz="0.20 0.11 0.09" rpy="0 1.25 0.3"/>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>

    <!-- 안테나 1 -->
    <visual>
      <origin xyz="-0.08 0.04 0.38"/>
      <geometry>
        <cylinder radius="0.006" length="0.18"/>
      </geometry>
      <material name="silver"/>
    </visual>

    <!-- 안테나 2 -->
    <visual>
      <origin xyz="-0.10 -0.04 0.34"/>
      <geometry>
        <cylinder radius="0.004" length="0.12"/>
      </geometry>
      <material name="silver"/>
    </visual>
  </link>

</robot>